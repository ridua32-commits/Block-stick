rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User entity
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'bestScore', 'updatedAt']) &&
             data.keys().size() <= 6 &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.bestScore is number && data.bestScore >= 0 &&
             data.updatedAt == request.time &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500);
    }

    match /users/{userId} {
      allow get: if true; // Public profiles for leaderboard
      allow list: if isSignedIn(); // Logged in users can see leaderboard
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming());
                      
      allow update: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid && // Immutable UID
                      incoming().diff(existing()).affectedKeys().hasOnly(['bestScore', 'displayName', 'photoURL', 'updatedAt']);
      
      allow delete: if false; // System doesn't allow account deletion yet
    }
  }
}
